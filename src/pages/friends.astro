---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import FriendCard from "../components/FriendCard.astro";
import FriendsEmptyState from "../components/FriendsEmptyState.astro";
import { friendsConfig } from "../config";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";

const hasLinks = friendsConfig.links.length > 0;
const pageTitle = friendsConfig.title ?? i18n(I18nKey.friends);
const pageDescription = friendsConfig.description ?? i18n(I18nKey.friends);
---

<MainGridLayout title={pageTitle} description={pageDescription}>
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <h1 class="text-4xl font-bold mb-4">{pageTitle}</h1>

      {friendsConfig.description && (
        <p class="text-gray-600 dark:text-gray-300 mb-8">
          {friendsConfig.description}
        </p>
      )}

      {hasLinks ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {friendsConfig.links.map((link) => (
            <FriendCard
              link={link}
              visitSiteLabel={i18n(I18nKey.visitSite)}
            />
          ))}
        </div>
      ) : (
        <FriendsEmptyState
          noFriendsLabel={i18n(I18nKey.noFriends)}
          hintLabel={i18n(I18nKey.noFriendsHint)}
        />
      )}
    </div>
  </div>
</MainGridLayout>
